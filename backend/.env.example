APP_ENV=development
API_BASE_URL=http://localhost:8000

GITHUB_TOKEN=
MAX_REPO_SIZE_KB=51200

SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

REDIS_URL=
REDIS_QUEUE_NAME=repo_scan_queue

FRONTEND_URL=http://localhost:8080

# Phase 2: repo cloning / file discovery
REPO_WORKSPACE_ROOT=/tmp/cqia/scans
GIT_CLONE_TIMEOUT_SECONDS=120
MAX_FILE_SIZE_BYTES=500000
MAX_TOTAL_FILES=5000

# Phase 2: Qdrant Cloud
QDRANT_URL=
QDRANT_API_KEY=
QDRANT_COLLECTION_CODE_CHUNKS=code_chunks

# Phase 2: Neo4j Aura
NEO4J_URI=
NEO4J_USERNAME=
NEO4J_PASSWORD=
NEO4J_DATABASE=neo4j

# Phase 2: embeddings (Qwen3-Embedding-0.6B via HuggingFace Inference API)
EMBEDDING_PROVIDER=huggingface
EMBEDDING_MODEL=Qwen/Qwen3-Embedding-0.6B
HF_API_TOKEN=

# Phase 2: worker
WORKER_CONCURRENCY=2

# Phase 3: OpenRouter LLM client
AGENT_LLM_PROVIDER=openrouter
AGENT_LLM_MODEL=deepseek/deepseek-chat-v3-0324
OPENROUTER_API_KEY_SUPERVISOR=
OPENROUTER_API_KEY_SECURITY=
OPENROUTER_API_KEY_PERFORMANCE=
OPENROUTER_API_KEY_COMPLEXITY=
OPENROUTER_API_KEY_DUPLICATION=
OPENROUTER_API_KEY_RELIABILITY=
AGENT_MAX_RETRIES=2
AGENT_TIMEOUT_SECONDS=120
LANGGRAPH_RECURSION_LIMIT=50
MAX_AGENT_CONTEXT_CHUNKS=12
MAX_FINDINGS_PER_AGENT=20

# Phase 4: Report generation & RAG chatbot
OPENROUTER_API_KEY_CHATBOT=
QDRANT_COLLECTION_AGENT_FINDINGS=agent_findings
QDRANT_COLLECTION_SCAN_REPORTS=scan_reports
